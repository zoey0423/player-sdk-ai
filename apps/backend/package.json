{
  "name": "@ai-player/backend",
  "version": "0.1.0",
  "private": true,
  "type": "commonjs",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
    "build": "rimraf dist && tsc",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "tsc --noEmit",
    "check-types": "tsc --noEmit",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate"
  },
  "dependencies": {
    "express": "^5.0.0",
    "@neondatabase/serverless": "^0.10.0",
    "drizzle-orm": "^0.40.0",
    "dotenv": "^16.4.7",
    "nanoid": "^5.1.5",
    "bcrypt": "^5.1.1",
    "jsonwebtoken": "^9.0.2",
    "express-rate-limit": "^7.5.0",
    "pino": "^9.6.0",
    "openai": "^4.94.0"
  },
  "devDependencies": {
    "@types/express": "^5.0.0",
    "@types/node": "^22.0.0",
    "@types/bcrypt": "^5.0.2",
    "@types/jsonwebtoken": "^9.0.9",
    "drizzle-kit": "^0.30.0",
    "rimraf": "^6.0.1",
    "ts-node-dev": "^2.0.0",
    "typescript": "5.9.2",
    "vitest": "^3.0.0",
    "supertest": "^7.1.0",
    "@types/supertest": "^6.0.2"
  }
}
